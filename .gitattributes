# Enforce LF line endings cho deploy files (quan trọng với AWS CodeBuild/CodeDeploy)
*.yml text eol=lf
*.yaml text eol=lf
*.sh text eol=lf
*.conf text eol=lf

# JS/HTML/CSS — mặc định LF
*.js text eol=lf
*.jsx text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.html text eol=lf
*.css text eol=lf
*.json text eol=lf

# Binary
*.png binary
*.jpg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
